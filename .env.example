# ══════════════════════════════════════════════════════════
#  Ekomat — Variables d'Environnement
#  Copie ce fichier en .env et remplis les valeurs
# ══════════════════════════════════════════════════════════

# ── Supabase (Obligatoire) ──
# URL du projet Supabase (Dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Clé publique "anon" (Dashboard > Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── Vercel (configuré automatiquement) ──
# VERCEL_URL est injecté par Vercel automatiquement

# ══════════════════════════════════════════════════════════
#  Configuration dans le Dashboard Vercel :
#  Settings > Environment Variables > Ajoute :
#    - VITE_SUPABASE_URL
#    - VITE_SUPABASE_ANON_KEY
# ══════════════════════════════════════════════════════════

# ── Tests E2E (Playwright, optionnel) ──
# Utilisés par playwright.e2e.config.mjs et le workflow e2e.yml.
# En CI : mets-les en GitHub Secrets (Settings > Secrets > Actions).
# Sans ces variables, les tests E2E se skippent (ils n'échouent pas).
# URL de l'app deployee a tester
AYM_E2E_URL=https://ayiti-market.vercel.app
# Compte de test acheteur (cree un vrai compte dedie aux tests)
AYM_E2E_EMAIL=test-buyer@example.com
AYM_E2E_PASSWORD=change-me
# Token Vercel "Deployment Protection" bypass (seulement pour un preview prive)
AYM_BYPASS_TOKEN=

# ── E2E : mode session injectee (optionnel, utile en local/sandbox) ──
# Si le navigateur ne peut pas se connecter via l'UI, injecte une session
# Supabase deja obtenue (JSON du token) au lieu de AYM_E2E_EMAIL/PASSWORD.
AYM_E2E_SESSION=
AYM_E2E_SB_REF=htxfwxldzaocuwezzbom
# Chemin local du SDK supabase-js si le CDN jsdelivr est bloque
AYM_E2E_SDK_PATH=

# ── Tests E2E API escrow (tests/e2e/escrow-api.spec.mjs) ──
# Pilotent la machine a etats escrow via l'API avec 3 vrais comptes.
AYM_E2E_SB_URL=https://htxfwxldzaocuwezzbom.supabase.co
AYM_E2E_ANON_KEY=
# service_role : requis pour creer/supprimer les commandes de test. Sensible.
AYM_E2E_SERVICE_KEY=
AYM_E2E_BUYER_EMAIL=
AYM_E2E_BUYER_PASSWORD=
AYM_E2E_ADMIN_EMAIL=
AYM_E2E_ADMIN_PASSWORD=
AYM_E2E_SELLER_EMAIL=
AYM_E2E_SELLER_PASSWORD=
