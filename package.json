{
  "name": "ekomat-tests",
  "version": "0.0.0",
  "private": true,
  "description": "Dev-only manifest for Playwright smoke tests. The app itself stays a single static index.html — no build, no runtime dependency.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "build:css": "tailwindcss -c tailwind.config.cjs -i scripts/tw-input.css -o assets/tw.css --minify"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.49.0",
    "tailwindcss": "^4.3.3"
  }
}
